# ------------------------------------------------------------
# 依存モジュール: npm install すれば再生成できるのでコミットしない
# ------------------------------------------------------------
node_modules/

# ------------------------------------------------------------
# macOS が勝手に作るメタファイル
# ------------------------------------------------------------
.DS_Store

# ------------------------------------------------------------
# ログ類
# ------------------------------------------------------------
*.log
npm-debug.log*

# ------------------------------------------------------------
# エディタ設定（人によって違うのでコミット不要）
# ------------------------------------------------------------
.vscode/
.idea/

# ------------------------------------------------------------
# Sass 中間ファイル
# ------------------------------------------------------------
.sass-cache/

# ------------------------------------------------------------
# 環境変数などの機密
# ------------------------------------------------------------
.env
.env.local

# ------------------------------------------------------------
# ビルド成果物（Gulpが自動生成するのでコミット不要）
# 本番公開は Cloudflare Pages 側で build → dist/ を配信する
# ------------------------------------------------------------
dist/
