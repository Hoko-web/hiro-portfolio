# ------------------------------------------------------------
.DS_Store

# ------------------------------------------------------------
# ログ類
# ------------------------------------------------------------
*.log
npm-debug.log*

# ------------------------------------------------------------
# エディタ設定（人によって違うのでコミット不要）
# ------------------------------------------------------------
.vscode/
.idea/

# ------------------------------------------------------------
# Sass 中間ファイル
